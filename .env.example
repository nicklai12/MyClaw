# === 訊息平台（至少填一個）===

# LINE（填 TOKEN + SECRET 即啟用）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Telegram（填 BOT_TOKEN 即啟用）
# TELEGRAM_BOT_TOKEN=

# === AI API Key（至少填一個）===
# 方案一：只用 Claude（付費，品質最好）
ANTHROPIC_API_KEY=

# 方案二：只用 Groq（免費，速度快）
# GROQ_API_KEY=

# 方案三：只用 Cerebras（免費，3000 tok/s 極速）
# CEREBRAS_API_KEY=

# 方案四：填 >=2 個（混合模式，簡單→Groq/Cerebras，複雜→Claude）

# === 模型選填 ===
# Groq 可用模型（預設 qwen/qwen3-32b）：
#   qwen/qwen3-32b                           — 免費主力，中文優秀
#   moonshotai/kimi-k2-instruct-0905          — Tool Calling 最強，中英雙語
#   meta-llama/llama-4-scout-17b-16e-instruct — Llama 4，額度大
#   meta-llama/llama-3.3-70b-versatile        — Llama 3.3，穩定可靠
#   qwen-qwq-32b                              — 推理型，適合複雜任務
#   openai/gpt-oss-120b                       — 中文能力差，不建議
#   mistralai/mistral-saba-24b                — Mistral 輕量
# GROQ_MODEL=qwen/qwen3-32b

# Claude 可用模型：
# CLAUDE_DEFAULT_MODEL=claude-haiku-4-5-20250501
# CLAUDE_COMPLEX_MODEL=claude-sonnet-4-5-20250514

# Cerebras 可用模型（預設 gpt-oss-120b）：
#   gpt-oss-120b                        — Production，3000 tok/s，131K context
#   qwen-3-235b-a22b-instruct-2507      — Preview，Qwen3 系列
#   zai-glm-4.7                         — Preview，RPD=100
# CEREBRAS_MODEL=gpt-oss-120b

# === MCP Servers（選填，JSON 陣列）===
# 連接外部 MCP Server 讓 Agent Skills 可使用瀏覽器、檔案系統等工具
# 格式：[{"name":"名稱","transport":{"type":"sse","url":"http://..."}}]
# 支援 stdio（本地子程序）和 sse（遠端服務）兩種 transport
# MCP_SERVERS=[{"name":"browser","transport":{"type":"stdio","command":"npx","args":["@playwright/mcp@latest","--headless","--isolated"]}}]

# === 其他選填 ===
# PORT=3000
# NODE_ENV=development
# WEBHOOK_BASE_URL=              # Telegram webhook 自動註冊（如 https://yourdomain.com）
